# Production Environment Variables
# Copy this to .env and fill in your actual values

FLASK_ENV=production
SECRET_KEY=your_secret_key_here
JWT_SECRET_KEY=your_jwt_secret_key_here

# Database — use ONE of the following:

# Recommended (Namecheap cPanel MySQL): full URI for Flask-SQLAlchemy + PyMySQL
# DATABASE_URL=mysql+pymysql://cpaneluser_dbuser:your_password@localhost/cpaneluser_dbname

# Alternative: split variables (built into mysql+pymysql://... automatically)
DB_HOST=localhost
DB_USER=your_database_user
DB_PASSWORD=your_database_password
DB_NAME=your_database_name

# Security Settings
JWT_COOKIE_SECURE=True
JWT_COOKIE_CSRF_PROTECT=True
