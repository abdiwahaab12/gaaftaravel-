# Production Environment Variables
# Copy this to .env and fill in your actual values

FLASK_ENV=production
SECRET_KEY=your_secret_key_here
JWT_SECRET_KEY=your_jwt_secret_key_here

# Database — use ONE of the following:

# Recommended (Namecheap cPanel MySQL): full URI for Flask-SQLAlchemy + PyMySQL
# Use exactly one @ before "localhost". If the password contains @, encode it as %40.
# DATABASE_URL=mysql+pymysql://gaaftnwn_gaaf_user:YOUR_PASSWORD@localhost/gaaftnwn_gaaf

# Alternative: split variables (built into mysql+pymysql://... automatically)
DB_HOST=localhost
DB_USER=gaaftnwn_gaaf_user
DB_PASSWORD=YOUR_PASSWORD
DB_NAME=gaaftnwn_gaaf

# Security Settings
JWT_COOKIE_SECURE=True
JWT_COOKIE_CSRF_PROTECT=True
